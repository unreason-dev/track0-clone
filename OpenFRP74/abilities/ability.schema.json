{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "title": "OpenFRP74 ability",
 "type": "object",
 "additionalProperties": false,
 "required": [
  "id",
  "name",
  "system",
  "description",
  "source"
 ],
 "properties": {
  "id": {
   "type": "string"
  },
  "name": {
   "type": "string"
  },
  "system": {
   "const": "openfrp74"
  },
  "prime_requisite_for": {
   "type": [
    "string",
    "null"
   ]
  },
  "exchange": {
   "type": "array",
   "items": {
    "type": "string"
   }
  },
  "modifiers": {
   "type": "array",
   "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
     "condition",
     "effect"
    ],
    "properties": {
     "condition": {
      "type": "string"
     },
     "effect": {
      "type": "string"
     },
     "note": {
      "type": [
       "string",
       "null"
      ]
     }
    }
   }
  },
  "description": {
   "type": "string"
  },
  "related": {
   "type": "array",
   "items": {
    "type": "string"
   }
  },
  "interpretation_records": {
   "type": "array",
   "items": {
    "type": "string"
   }
  },
  "source": {
   "type": "object"
  },
  "extraction": {
   "type": "object"
  }
 }
}